<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pemandu Wisata Inklusif"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <ImageButton
        android:id="@+id/btnMic"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_btn_speak_now"
        android:backgroundTint="#4CAF50"
        android:contentDescription="Ketuk untuk bicara dan mencari artefak"
        android:importantForAccessibility="yes"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvLiveText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mendengarkan..."
        android:textSize="16sp"
        android:textStyle="italic"
        android:textColor="#FF5722"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvResultTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Data Artefak"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvResultDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Informasi akan dibacakan di sini."
            android:textSize="16sp" />
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Asisten Waktu (Ketuk 2x untuk setel):"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnAlarm1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 Menit (Test)"
            android:contentDescription="Atur pengingat satu menit"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnAlarm30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="30 Menit"
            android:contentDescription="Atur pengingat tiga puluh menit"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aqila Adam"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="#888888" />

</LinearLayout>